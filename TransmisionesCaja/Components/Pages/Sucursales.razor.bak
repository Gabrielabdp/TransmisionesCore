@page "/sucursales"
@using TransmisionesCaja.Auth
@using TransmisionesCaja.Services
@inject ApiService Api
@inject AuthService Auth
@rendermode InteractiveServer

@if (!Auth.EsAdmin())
{
    <div class="acceso-denegado">🚫 Solo los administradores pueden acceder a esta sección.</div>
    return;
}

<div class="page-header">
    <div>
        <h2>🏢 Sucursales</h2>
        <p>Gestión de locales y sucursales</p>
    </div>
    <button class="btn-primary" @onclick="AbrirNuevo">+ Nueva Sucursal</button>
</div>

@if (cargando)
{
    <div class="loading">Cargando sucursales...</div>
}
else
{
    <div class="cards-grid">
        @foreach (var s in sucursales)
        {
            <div class="card-sucursal">
                <div class="card-header-s">
                    <span class="icon-s">🏢</span>
                    <div>
                        <h4>@s.Nombre_sucursal</h4>
                        <span class="@(s.Activa ? "badge-activo" : "badge-inactivo")">
                            @(s.Activa ? "Activa" : "Inactiva")
                        </span>
                    </div>
                </div>
                <div class="card-body-s">
                    <p>📍 @(s.Direccion ?? "Sin dirección")</p>
                    <p>📞 @(s.Telefono ?? "Sin teléfono")</p>
                </div>
                <div class="card-footer-s">
                    <button class="btn-edit" @onclick="() => AbrirEditar(s)">✏️ Editar</button>
                </div>
            </div>
        }
    </div>
}

@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(esNuevo ? "Nueva Sucursal" : "Editar Sucursal")</h3>
                <button class="btn-close" @onclick="CerrarModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(mensajeError))
                { <div class="alert-error">⚠️ @mensajeError</div> }
                @if (!string.IsNullOrEmpty(mensajeExito))
                { <div class="alert-exito">✅ @mensajeExito</div> }

                <div class="form-group">
                    <label>Nombre de la Sucursal *</label>
                    <input @bind="form.NombreSucursal" class="input-field" placeholder="Ej: Sucursal Norte" />
                </div>
                <div class="form-group">
                    <label>Dirección</label>
                    <input @bind="form.Direccion" class="input-field" placeholder="Calle, número, sector" />
                </div>
                <div class="form-group">
                    <label>Teléfono</label>
                    <input @bind="form.Telefono" class="input-field" placeholder="809-000-0000" />
                </div>

                <!-- ✅ Provincia primero, luego municipios filtrados -->
                <div class="form-group">
                    <label>Provincia *</label>
                    <select value="@form.IdProvincia" @onchange="OnProvinciaChanged" class="input-field">
                        <option value="0">-- Seleccionar --</option>
                        @foreach (var p in provincias)
                        {
                            <option value="@p.Id_provincia">@p.Nombre_provincia</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Municipio *</label>
                    <select @bind="form.IdMunicipio" class="input-field">
                        <option value="0">-- Seleccionar --</option>
                        @foreach (var m in municipios)
                        {
                            <option value="@m.Id_municipio">@m.Nombre_municipio</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CerrarModal">Cancelar</button>
                <button class="btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "💾 Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    List<SucursalDto>  sucursales = new();
    List<ProvinciaDto> provincias = new();  // ✅ nuevo
    List<MunicipioDto> municipios = new();
    bool cargando = true; bool mostrarModal = false;
    bool esNuevo = true;  bool guardando    = false;
    int  editId  = 0;
    string mensajeError = string.Empty; string mensajeExito = string.Empty;
    SucursalForm form = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            sucursales = await Api.GetSucursalesAsync();
            provincias = await Api.GetProvinciasAsync();  // ✅ carga provincias
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        cargando = false;
    }

    // ✅ Al cambiar provincia, carga sus municipios
    async Task OnProvinciaChanged(ChangeEventArgs e)
    {
        form.IdProvincia = int.Parse(e.Value?.ToString() ?? "0");
        form.IdMunicipio = 0;
        municipios = form.IdProvincia > 0
            ? await Api.GetMunicipiosAsync(form.IdProvincia)
            : new();
    }

    void AbrirNuevo()
    {
        esNuevo = true;
        form = new();
        mensajeError = mensajeExito = string.Empty;
        mostrarModal = true;
    }

    void AbrirEditar(SucursalDto s)
    {
        esNuevo = false;
        editId  = s.Id_sucursal;
        form    = new() { NombreSucursal = s.Nombre_sucursal, Direccion = s.Direccion, Telefono = s.Telefono, IdMunicipio = s.Id_municipio };
        mensajeError = mensajeExito = string.Empty;
        mostrarModal = true;
    }

    void CerrarModal() => mostrarModal = false;

    async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(form.NombreSucursal) || form.IdMunicipio == 0)
        { mensajeError = "Completa los campos obligatorios."; return; }

        guardando = true;
        bool ok;
        if (esNuevo)
            ok = await Api.CrearSucursalAsync(new { IdMunicipio = form.IdMunicipio, NombreSucursal = form.NombreSucursal, Direccion = form.Direccion, Telefono = form.Telefono });
        else
            ok = await Api.ActualizarSucursalAsync(editId, new { IdMunicipio = form.IdMunicipio, NombreSucursal = form.NombreSucursal, Direccion = form.Direccion, Telefono = form.Telefono });

        guardando = false;
        if (ok) { mensajeExito = "Guardado correctamente."; sucursales = await Api.GetSucursalesAsync(); await Task.Delay(1500); CerrarModal(); }
        else mensajeError = "Error al guardar. Intenta de nuevo.";
    }

    class SucursalForm
    {
        public string  NombreSucursal { get; set; } = string.Empty;
        public string? Direccion      { get; set; }
        public string? Telefono       { get; set; }
        public int     IdProvincia    { get; set; }  // ✅ nuevo
        public int     IdMunicipio    { get; set; }
    }
}

<style>
    .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; }
    .page-header h2 { margin:0; font-size:22px; color:#1e293b; }
    .page-header p { margin:4px 0 0; color:#64748b; font-size:13px; }
    .btn-primary { background:#0ea5e9; color:white; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-size:14px; font-weight:600; }
    .btn-primary:hover:not(:disabled) { background:#0284c7; }
    .btn-primary:disabled { background:#93c5fd; cursor:not-allowed; }
    .btn-secondary { background:#e2e8f0; color:#374151; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; }
    .btn-edit { background:#f1f5f9; border:1px solid #d1d5db; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .cards-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:20px; }
    .card-sucursal { background:white; border-radius:10px; box-shadow:0 1px 4px rgba(0,0,0,0.08); padding:20px; }
    .card-header-s { display:flex; gap:12px; align-items:flex-start; margin-bottom:14px; }
    .icon-s { font-size:28px; }
    .card-header-s h4 { margin:0 0 4px; font-size:15px; color:#1e293b; }
    .card-body-s p { margin:4px 0; font-size:13px; color:#64748b; }
    .card-footer-s { margin-top:14px; border-top:1px solid #f1f5f9; padding-top:12px; }
    .badge-activo { background:#dcfce7; color:#166534; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-inactivo { background:#fee2e2; color:#991b1b; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .loading { text-align:center; padding:40px; color:#64748b; }
    .acceso-denegado { background:#fef2f2; border:1px solid #fecaca; color:#dc2626; padding:20px; border-radius:8px; text-align:center; }
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000; }
    .modal { background:white; border-radius:12px; width:580px; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .modal-header { display:flex; justify-content:space-between; align-items:center; padding:20px 24px; border-bottom:1px solid #e2e8f0; }
    .modal-header h3 { margin:0; font-size:17px; color:#1e293b; }
    .btn-close { background:none; border:none; font-size:18px; cursor:pointer; color:#64748b; }
    .modal-body { padding:24px; display:flex; flex-direction:column; gap:16px; }
    .modal-footer { padding:16px 24px; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end; gap:10px; }
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-group label { font-size:13px; font-weight:600; color:#374151; }
    .input-field { padding:9px 12px; border:1.5px solid #d1d5db; border-radius:8px; font-size:14px; }
    .input-field:focus { outline:none; border-color:#0ea5e9; }
    .alert-error { background:#fef2f2; border:1px solid #fecaca; color:#dc2626; padding:10px 14px; border-radius:8px; font-size:13px; }
    .alert-exito { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; padding:10px 14px; border-radius:8px; font-size:13px; }
</style>