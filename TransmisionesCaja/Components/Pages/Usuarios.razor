@page "/usuarios"
@using TransmisionesCaja.Auth
@using TransmisionesCaja.Services
@inject ApiService Api
@inject AuthService Auth
@rendermode InteractiveServer

@if (!Auth.EsAdmin())
{
    <div class="acceso-denegado-container">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        <p>Solo los administradores pueden acceder a esta sección.</p>
    </div>
    return;
}

<style>
    /* RESET DE COLORES CON SOPORTE A VARIABLES (MODO CLARO/OSCURO) */
    .page-title { color: var(--text-primary, #ffffff) !important; font-weight: 700; }
    .page-subtitle { color: var(--text-muted, #94a3b8) !important; }
    .page-count { color: #60a5fa !important; font-weight: 600; }

    /* CONTENEDOR DE TABLA */
    .table-wrapper { 
        background: var(--bg-card, #111827); 
        border-radius: 12px; 
        border: 1px solid var(--border-color, #1f2937); 
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .custom-table { width: 100%; border-collapse: collapse; }
    
    .custom-table th {
        background: var(--bg-card, #1f2937);
        color: var(--text-muted, #94a3b8);
        font-size: 11px;
        text-transform: uppercase;
        padding: 14px 16px;
        text-align: left;
        letter-spacing: 0.05em;
        border-bottom: 1px solid var(--border-color, #1f2937);
    }

    .custom-table td { 
        padding: 16px; 
        border-bottom: 1px solid var(--border-color, #1f2937); 
        color: var(--text-primary, #e5e7eb); 
        font-size: 14px;
        vertical-align: middle;
    }

    /* PERFIL Y AVATAR */
    .user-profile-cell { display: flex; align-items: center; gap: 12px; }
    
    .user-avatar {
        width: 38px; height: 38px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 12px;
        background: #3b82f6; color: #ffffff;
    }

    .user-name { font-weight: 700; color: var(--text-primary, #ffffff) !important; display: block; }
    .user-meta { font-size: 12px; color: var(--text-muted, #64748b); }

    /* BADGES (ROLES) */
    .badge-role {
        padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600;
    }
    .badge-indigo { background: rgba(79, 70, 229, 0.2); color: #818cf8; border: 1px solid rgba(79, 70, 229, 0.3); }
    .badge-amber { background: rgba(217, 119, 6, 0.2); color: #fbbf24; border: 1px solid rgba(217, 119, 6, 0.3); }
    .badge-purple { background: rgba(147, 51, 234, 0.2); color: #c084fc; border: 1px solid rgba(147, 51, 234, 0.3); }

    /* ESTADO (DOTS) */
    .status-indicator {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 12px; font-weight: 600;
        padding: 4px 10px; border-radius: 20px;
    }
    .is-active { background: rgba(16, 185, 129, 0.1); color: #34d399; }
    .is-inactive { background: rgba(239, 68, 68, 0.1); color: #f87171; }
    .dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
    .is-active .dot { background: #10b981; box-shadow: 0 0 8px #10b981; }
    .is-inactive .dot { background: #ef4444; }

    /* BOTONES */
    .btn-primary {
        background: #0ea5e9; color: white; border: none; padding: 10px 20px; 
        border-radius: 8px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px;
    }
    .btn-action-v2 {
        background: transparent; border: none; color: var(--text-muted, #64748b); padding: 8px; border-radius: 6px; cursor: pointer;
    }
    .btn-action-v2:hover { background: var(--bg-main, #1f2937); color: var(--text-primary, #ffffff); }
    .btn-action-v2.danger:hover { background: rgba(239, 68, 68, 0.1); color: #f87171; }

    /* MODALES */
    .modal-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center; z-index: 2000;
    }
    .modal {
        background: var(--bg-card, #111827); border: 1px solid var(--border-color, #1f2937); border-radius: 16px;
        width: 100%; max-width: 480px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
    }
    .modal-header { padding: 24px; display: flex; justify-content: space-between; align-items: flex-start; }
    .modal-title { font-size: 1.25rem; font-weight: 700; color: var(--text-primary, #ffffff); margin: 0; }
    .modal-subtitle { font-size: 0.875rem; color: var(--text-muted, #94a3b8); margin: 4px 0 0; }
    .btn-close-modal { background: none; border: none; color: var(--text-muted, #64748b); cursor: pointer; padding: 4px; border-radius: 6px; }
    .btn-close-modal:hover { background: var(--bg-main, #1f2937); color: var(--text-primary, #ffffff); }
    .modal-body { padding: 24px; }
    .form-group { margin-bottom: 20px; }
    .form-label { display: block; font-size: 13px; font-weight: 600; color: var(--text-muted, #94a3b8); margin-bottom: 8px; }
    .input-field {
        width: 100%; background: var(--bg-main, #0f172a); border: 1px solid var(--border-color, #1f2937); border-radius: 8px;
        padding: 10px 14px; color: var(--text-primary, #ffffff); font-size: 14px; outline: none; transition: border-color 0.2s;
    }
    .input-field:focus { border-color: #0ea5e9; }
    .modal-footer { padding: 20px 24px; background: var(--bg-card, #1f2937); display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--border-color, #1f2937); }
    .btn-secondary { background: transparent; border: 1px solid var(--border-color, #334155); color: var(--text-primary, #e5e7eb); padding: 10px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; }
    .btn-secondary:hover { background: var(--bg-main, #334155); }
    
    .alert-warning {
        background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2);
        padding: 16px; border-radius: 12px; display: flex; gap: 12px; color: #f87171; margin-bottom: 20px;
    }
    .alert-warning svg { width: 24px; flex-shrink: 0; }
    .alert-warning-title { font-weight: 700; font-size: 14px; margin-bottom: 2px; }
    .alert-warning-text { font-size: 13px; opacity: 0.9; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Usuarios <span class="page-count">· @usuarios.Count</span></h1>
        <p class="page-subtitle">Gestiona las cuentas de acceso y roles del sistema</p>
    </div>
    <button class="btn-primary" @onclick="AbrirNuevo">
        <svg style="width:20px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
        Nuevo Usuario
    </button>
</div>

@if (!string.IsNullOrEmpty(mensajeExito))
{
    <div style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); color: #34d399; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
        <svg style="width:20px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
        @mensajeExito
    </div>
}

@if (cargando)
{
    <div style="color: var(--text-muted, #94a3b8); text-align: center; padding: 40px;">Cargando usuarios...</div>
}
else
{
    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th style="text-align:right;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in usuarios)
                {
                    <tr>
                        <td style="font-family: monospace; color: var(--text-muted, #64748b);">#@u.Id_usuario.ToString("D2")</td>
                        <td>
                            <div class="user-profile-cell">
                                <div class="user-avatar">
                                    @u.Nombre_usuario.Substring(0, Math.Min(2, u.Nombre_usuario.Length)).ToUpper()
                                </div>
                                <div class="user-details">
                                    <span class="user-name">@u.Nombre_usuario</span>
                                    <span class="user-meta">@u.Nombre_usuario@@sistema</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge-role @GetRolBadge(u.Rol)">
                                @u.Rol
                            </span>
                        </td>
                        <td>
                            <div class="status-indicator @(u.Activo ? "is-active" : "is-inactive")">
                                <span class="dot"></span>
                                @(u.Activo ? "Activo" : "Inactivo")
                            </div>
                        </td>
                        <td>
                            <div style="display: flex; justify-content: flex-end; gap: 8px;">
                                <button class="btn-action-v2" @onclick="() => AbrirEditar(u)">
                                    <svg style="width:18px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                </button>
                                @if (u.Activo)
                                {
                                    <button class="btn-action-v2 danger" @onclick="() => ConfirmarDesactivar(u)">
                                        <svg style="width:18px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <h2 class="modal-title">@(esNuevo ? "Nuevo Usuario" : "Editar Usuario")</h2>
                    <p class="modal-subtitle">@(esNuevo ? "Crea una cuenta de acceso" : "Modifica los permisos de la cuenta")</p>
                </div>
                <button class="btn-close-modal" @onclick="CerrarModal">
                    <svg style="width:20px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(mensajeErrorModal))
                {
                    <div style="color: #f87171; font-size: 13px; margin-bottom: 16px;">@mensajeErrorModal</div>
                }

                <div class="form-group">
                    <label class="form-label">Nombre de Usuario</label>
                    <input @bind="form.NombreUsuario" class="input-field" placeholder="ej. jdoe" />
                </div>

                <div class="form-group">
                    <label class="form-label">Contraseña @(esNuevo ? "*" : "(dejar en blanco para no cambiar)")</label>
                    <input type="password" @bind="form.Contrasena" class="input-field" placeholder="••••••••" />
                </div>

                <div class="form-group">
                    <label class="form-label">Rol del Sistema</label>
                    <select @bind="form.Rol" class="input-field">
                        <option value="Admin">Administrador</option>
                        <option value="Cajero">Cajero</option>
                        <option value="Tecnico">Técnico</option>
                    </select>
                </div>

                @if (!esNuevo)
                {
                    <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
                        <input type="checkbox" @bind="form.Activo" id="chkActivo" />
                        <label for="chkActivo" class="form-label" style="margin: 0;">Usuario Activo</label>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CerrarModal">Cancelar</button>
                <button class="btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "Guardar Usuario")
                </button>
            </div>
        </div>
    </div>
}

@if (mostrarConfirm)
{
    <div class="modal-overlay" @onclick="() => mostrarConfirm = false">
        <div class="modal" style="max-width:400px;" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <h2 class="modal-title">¿Desactivar usuario?</h2>
                    <p class="modal-subtitle">El usuario no podrá iniciar sesión</p>
                </div>
            </div>
            <div class="modal-body">
                <div class="alert-warning">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                    <div>
                        <div class="alert-warning-title">Confirmar acción</div>
                        <div class="alert-warning-text">¿Estás seguro de que deseas desactivar a <strong>@usuarioADesactivar?.Nombre_usuario</strong>?</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="() => mostrarConfirm = false">Cancelar</button>
                <button class="btn-primary" style="background: #ef4444;" @onclick="EjecutarDesactivar" disabled="@guardando">
                    @(guardando ? "Procesando..." : "Sí, desactivar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    List<UsuarioDto> usuarios = new();
    bool cargando = true; bool mostrarModal = false; bool mostrarConfirm = false;
    bool esNuevo = true; bool guardando = false;
    int editId = 0;
    string mensajeError = string.Empty; string mensajeExito = string.Empty;
    string mensajeErrorModal = string.Empty;
    UsuarioForm form = new();
    UsuarioDto? usuarioADesactivar = null;

    protected override async Task OnInitializedAsync() => await CargarDatos();

    async Task CargarDatos()
    {
        cargando = true;
        try { usuarios = await Api.GetUsuariosAsync(); }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        cargando = false;
        StateHasChanged();
    }

    void AbrirNuevo() { esNuevo = true; form = new(); mensajeErrorModal = string.Empty; mostrarModal = true; }
    void AbrirEditar(UsuarioDto u)
    {
        esNuevo = false;
        editId = u.Id_usuario;
        form = new() { NombreUsuario = u.Nombre_usuario, Rol = u.Rol, Activo = u.Activo };
        mensajeErrorModal = string.Empty;
        mostrarModal = true;
    }
    void CerrarModal() => mostrarModal = false;
    void ConfirmarDesactivar(UsuarioDto u) { usuarioADesactivar = u; mostrarConfirm = true; }

    async Task EjecutarDesactivar()
    {
        if (usuarioADesactivar == null) return;
        guardando = true;
        StateHasChanged();
        
        var ok = await Api.EliminarUsuarioAsync(usuarioADesactivar.Id_usuario);
        if (ok) 
        { 
            mensajeExito = $"Usuario '{usuarioADesactivar.Nombre_usuario}' desactivado correctamente.";
            await CargarDatos(); 
            mostrarConfirm = false;
            StateHasChanged();
            _ = Task.Delay(3000).ContinueWith(_ => { mensajeExito = string.Empty; InvokeAsync(StateHasChanged); });
        }
        else
        {
            mensajeError = "No se pudo desactivar el usuario.";
        }
        
        guardando = false;
        mostrarConfirm = false;
        StateHasChanged();
    }

    async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(form.NombreUsuario)) { mensajeErrorModal = "El nombre de usuario es obligatorio."; return; }
        if (esNuevo && string.IsNullOrWhiteSpace(form.Contrasena)) { mensajeErrorModal = "La contraseña es obligatoria."; return; }
        
        guardando = true;
        mensajeErrorModal = string.Empty;
        StateHasChanged();

        // Aseguramos que los nombres de las propiedades coincidan con la API
        var payload = new 
        { 
            Nombre_usuario = form.NombreUsuario, 
            Rol = form.Rol, 
            Activo = form.Activo,
            Contrasena = string.IsNullOrWhiteSpace(form.Contrasena) ? null : form.Contrasena 
        };

        bool ok = esNuevo
            ? await Api.CrearUsuarioAsync(payload)
            : await Api.ActualizarUsuarioAsync(editId, payload);
        
        if (ok) 
        { 
            mensajeExito = esNuevo ? "Usuario creado correctamente." : "Usuario actualizado correctamente.";
            await CargarDatos(); 
            CerrarModal(); 
            StateHasChanged();
            _ = Task.Delay(3000).ContinueWith(_ => { mensajeExito = string.Empty; InvokeAsync(StateHasChanged); });
        }
        else 
        {
            mensajeErrorModal = "Error al guardar. Puede que el nombre de usuario ya exista.";
        }
        guardando = false;
        StateHasChanged();
    }

    string GetRolBadge(string rol) => rol?.ToLower() switch { "admin" => "badge-indigo", "cajero" => "badge-amber", "tecnico" => "badge-purple", _ => "badge-indigo" };

    class UsuarioForm { public string NombreUsuario { get; set; } = string.Empty; public string Rol { get; set; } = "Cajero"; public string? Contrasena { get; set; } public bool Activo { get; set; } = true; }
}