@page "/usuarios"
@using TransmisionesCaja.Auth
@using TransmisionesCaja.Services
@inject ApiService Api
@inject AuthService Auth
@rendermode InteractiveServer

@if (!Auth.EsAdmin())
{
    <div class="acceso-denegado">🚫 Solo los administradores pueden acceder a esta sección.</div>
    return;
}

<div class="page-header">
    @if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="alert-error" style="margin-bottom:16px;">⚠️ @mensajeError</div>
}
@if (!string.IsNullOrEmpty(mensajeExito))
{
    <div class="alert-exito" style="margin-bottom:16px;">✅ @mensajeExito</div>
}
    <div>
        <h2>👤 Usuarios</h2>
        <p>Cuentas de acceso al sistema</p>
    </div>
    <button class="btn-primary" @onclick="AbrirNuevo">+ Nuevo Usuario</button>
</div>

@if (cargando)
{
    <div class="loading">Cargando usuarios...</div>
}
else
{
    <div class="tabla-wrapper">
        <table class="tabla">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in usuarios)
                {
                    <tr>
                        <td>@u.Id_usuario</td>
                        <td><strong>@u.Nombre_usuario</strong></td>
                        <td><span class="badge-rol-@u.Rol.ToLower()">@u.Rol</span></td>
                        <td>
                            @if (u.Activo)
                            { <span class="badge-activo">Activo</span> }
                            else
                            { <span class="badge-inactivo">Inactivo</span> }
                        </td>
                        <td class="acciones">
                            <button class="btn-edit" @onclick="() => AbrirEditar(u)">✏️ Editar</button>
                            @if (u.Activo)
                            {
                                <button class="btn-danger" @onclick="() => ConfirmarDesactivar(u)">🚫 Desactivar</button>
                            }
                            else
                            {
                                <button class="btn-success" @onclick="() => Reactivar(u)">✅ Reactivar</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- MODAL CREAR / EDITAR -->
@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(esNuevo ? "Nuevo Usuario" : "Editar Usuario")</h3>
                <button class="btn-close" @onclick="CerrarModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(mensajeError))
                { <div class="alert-error">⚠️ @mensajeError</div> }
                @if (!string.IsNullOrEmpty(mensajeExito))
                { <div class="alert-exito">✅ @mensajeExito</div> }

                <div class="form-grid">
                    <div class="form-group">
                        <label>Nombre de usuario *</label>
                        <input @bind="form.NombreUsuario" class="input-field" placeholder="ej: jperez" />
                    </div>
                    <div class="form-group">
                        <label>Rol *</label>
                        <select @bind="form.Rol" class="input-field">
                            <option value="">-- Seleccionar --</option>
                            <option value="Admin">Admin</option>
                            <option value="Cajero">Cajero</option>
                            <option value="Tecnico">Tecnico</option>
                        </select>
                    </div>
                    <div class="form-group span-2">
                        <label>@(esNuevo ? "Contraseña *" : "Nueva contraseña (dejar vacío para no cambiar)")</label>
                        <input type="password" @bind="form.Contrasena" class="input-field" placeholder="••••••••" />
                    </div>
                    @if (!esNuevo)
                    {
                        <div class="form-group">
    <label>Estado</label>
    <select value="@form.Activo" @onchange="@(e => form.Activo = e.Value?.ToString() == "true")" class="input-field">
        <option value="true" selected="@form.Activo">Activo</option>
        <option value="false" selected="@(!form.Activo)">Inactivo</option>
    </select>
</div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CerrarModal">Cancelar</button>
                <button class="btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "💾 Guardar")
                </button>
            </div>
        </div>
    </div>
}

<!-- MODAL CONFIRMAR DESACTIVAR -->
@if (mostrarConfirm)
{
    <div class="modal-overlay" @onclick="() => mostrarConfirm = false">
        <div class="modal-confirm" @onclick:stopPropagation>
            <h3>⚠️ ¿Desactivar usuario?</h3>
            <p>El usuario <strong>@usuarioADesactivar?.Nombre_usuario</strong> no podrá iniciar sesión hasta que sea reactivado.</p>
            <div class="confirm-footer">
                <button class="btn-secondary" @onclick="() => mostrarConfirm = false">Cancelar</button>
                <button class="btn-danger" @onclick="EjecutarDesactivar" disabled="@guardando">
                    @(guardando ? "Procesando..." : "Sí, desactivar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    void CambiarEstado(ChangeEventArgs e)
{
    form.Activo = e.Value?.ToString() == "true";
}
    List<UsuarioDto> usuarios = new();
    bool   cargando       = true;
    bool   mostrarModal   = false;
    bool   mostrarConfirm = false;
    bool   esNuevo        = true;
    bool   guardando      = false;
    int    editId         = 0;
    string mensajeError   = string.Empty;
    string mensajeExito   = string.Empty;

    UsuarioForm  form               = new();
    UsuarioDto?  usuarioADesactivar = null;

    protected override async Task OnInitializedAsync() => await CargarDatos();

    async Task CargarDatos()
    {
        cargando = true;
        try { usuarios = await Api.GetUsuariosAsync(); }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        cargando = false;
    }

    void AbrirNuevo()
    {
        esNuevo      = true;
        form         = new();
        mensajeError = mensajeExito = string.Empty;
        mostrarModal = true;
    }

    void AbrirEditar(UsuarioDto u)
    {
        esNuevo = false;
        editId  = u.Id_usuario;
        form    = new() { NombreUsuario = u.Nombre_usuario, Rol = u.Rol, Activo = u.Activo };
        mensajeError = mensajeExito = string.Empty;
        mostrarModal = true;
    }

    void CerrarModal() => mostrarModal = false;

    void ConfirmarDesactivar(UsuarioDto u)
    {
        usuarioADesactivar = u;
        mostrarConfirm     = true;
    }

    async Task EjecutarDesactivar()
{
    if (usuarioADesactivar == null) return;
    guardando = true;
    var ok = await Api.EliminarUsuarioAsync(usuarioADesactivar.Id_usuario);
    guardando = false;
    mostrarConfirm = false;

    if (ok)
    {
        mensajeExito = "Usuario desactivado correctamente.";
        mensajeError = string.Empty;
        await CargarDatos();
        await Task.Delay(3000);
        mensajeExito = string.Empty;
    }
    else
    {
        mensajeError = $"No se puede desactivar '{usuarioADesactivar.Nombre_usuario}': tiene un empleado activo vinculado.";
        mensajeExito = string.Empty;
        await Task.Delay(4000);
        mensajeError = string.Empty;
        StateHasChanged();
    }
}

    async Task Reactivar(UsuarioDto u)
    {
        var ok = await Api.ActualizarUsuarioAsync(u.Id_usuario, new
        {
            Nombre_usuario = u.Nombre_usuario,
            Rol            = u.Rol,
            Activo         = true,
            Contrasena     = (string?)null
        });
        if (ok) await CargarDatos();
    }

    async Task Guardar()
    {
        mensajeError = string.Empty;

        if (string.IsNullOrWhiteSpace(form.NombreUsuario) || string.IsNullOrWhiteSpace(form.Rol))
        { mensajeError = "Completa todos los campos obligatorios."; return; }

        if (esNuevo && string.IsNullOrWhiteSpace(form.Contrasena))
        { mensajeError = "La contraseña es obligatoria para nuevos usuarios."; return; }

        guardando = true;
        bool ok;

        if (esNuevo)
        {
            ok = await Api.CrearUsuarioAsync(new
            {
                Nombre_usuario = form.NombreUsuario,
                Contrasena     = form.Contrasena!,
                Rol            = form.Rol
            });
        }
        else
        {
            ok = await Api.ActualizarUsuarioAsync(editId, new
            {
                Nombre_usuario = form.NombreUsuario,
                Rol            = form.Rol,
                Activo         = form.Activo,
                Contrasena     = string.IsNullOrWhiteSpace(form.Contrasena) ? null : form.Contrasena
            });
        }

        guardando = false;

        if (ok)
        {
            mensajeExito = esNuevo ? "Usuario creado correctamente." : "Usuario actualizado correctamente.";
            await CargarDatos();
            await Task.Delay(1500);
            CerrarModal();
        }
        else
        {
            mensajeError = "Ocurrió un error. El nombre de usuario puede estar en uso.";
        }
    }

    class UsuarioForm
    {
        public string  NombreUsuario { get; set; } = string.Empty;
        public string  Rol           { get; set; } = string.Empty;
        public string? Contrasena    { get; set; }
        public bool    Activo        { get; set; } = true;
    }
}

<style>
    .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; }
    .page-header h2 { margin:0; font-size:22px; color:#1e293b; }
    .page-header p { margin:4px 0 0; color:#64748b; font-size:13px; }
    .btn-primary { background:#0ea5e9; color:white; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-size:14px; font-weight:600; }
    .btn-primary:hover:not(:disabled) { background:#0284c7; }
    .btn-primary:disabled { background:#93c5fd; cursor:not-allowed; }
    .btn-secondary { background:#e2e8f0; color:#374151; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-size:14px; }
    .btn-edit { background:#f1f5f9; border:1px solid #d1d5db; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .btn-edit:hover { background:#e2e8f0; }
    .btn-danger { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .btn-danger:hover:not(:disabled) { background:#fecaca; }
    .btn-danger:disabled { opacity:.6; cursor:not-allowed; }
    .btn-success { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .btn-success:hover { background:#bbf7d0; }
    .acciones { display:flex; gap:6px; }
    .tabla-wrapper { background:white; border-radius:10px; box-shadow:0 1px 4px rgba(0,0,0,0.08); overflow:hidden; }
    .tabla { width:100%; border-collapse:collapse; font-size:13px; }
    .tabla thead { background:#f8fafc; }
    .tabla th { padding:12px 14px; text-align:left; font-size:12px; color:#64748b; text-transform:uppercase; letter-spacing:.5px; border-bottom:1px solid #e2e8f0; }
    .tabla td { padding:12px 14px; border-bottom:1px solid #f1f5f9; color:#374151; vertical-align:middle; }
    .tabla tr:last-child td { border-bottom:none; }
    .tabla tr:hover td { background:#f8fafc; }
    .badge-activo { background:#dcfce7; color:#166534; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-inactivo { background:#fee2e2; color:#991b1b; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-rol-admin { background:#dbeafe; color:#1e40af; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-rol-cajero { background:#fef9c3; color:#854d0e; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-rol-tecnico { background:#f3e8ff; color:#6b21a8; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:600; }
    .loading { text-align:center; padding:40px; color:#64748b; }
    .acceso-denegado { background:#fef2f2; border:1px solid #fecaca; color:#dc2626; padding:20px; border-radius:8px; text-align:center; }
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000; }
    .modal { background:white; border-radius:12px; width:520px; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .modal-confirm { background:white; border-radius:12px; width:420px; padding:28px; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .modal-confirm h3 { margin:0 0 12px; font-size:17px; color:#1e293b; }
    .modal-confirm p { margin:0 0 20px; color:#64748b; font-size:14px; }
    .confirm-footer { display:flex; justify-content:flex-end; gap:10px; }
    .modal-header { display:flex; justify-content:space-between; align-items:center; padding:20px 24px; border-bottom:1px solid #e2e8f0; }
    .modal-header h3 { margin:0; font-size:17px; color:#1e293b; }
    .btn-close { background:none; border:none; font-size:18px; cursor:pointer; color:#64748b; }
    .modal-body { padding:24px; }
    .modal-footer { padding:16px 24px; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end; gap:10px; }
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-group.span-2 { grid-column: span 2; }
    .form-group label { font-size:13px; font-weight:600; color:#374151; }
    .input-field { padding:9px 12px; border:1.5px solid #d1d5db; border-radius:8px; font-size:14px; }
    .input-field:focus { outline:none; border-color:#0ea5e9; }
    .alert-error { background:#fef2f2; border:1px solid #fecaca; color:#dc2626; padding:10px 14px; border-radius:8px; font-size:13px; margin-bottom:14px; }
    .alert-exito { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; padding:10px 14px; border-radius:8px; font-size:13px; margin-bottom:14px; }
</style>