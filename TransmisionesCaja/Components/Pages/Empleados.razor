@page "/empleados"
@using TransmisionesCaja.Auth
@using TransmisionesCaja.Services
@inject ApiService Api
@inject AuthService Auth
@rendermode InteractiveServer

@if (!Auth.EsAdmin())
{
    <div class="acceso-denegado">Solo los administradores pueden acceder a esta sección.</div>
    return;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Empleados <span class="page-count">· @empleados.Count</span></h1>
        <p class="page-subtitle">Gestión del personal del sistema</p>
    </div>
    <button class="btn-primary" @onclick="AbrirFormularioNuevo">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
        Nuevo Empleado
    </button>
</div>

@if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="alert-error" style="margin-bottom:16px;"><svg fill="currentColor" viewBox="0 0 20 20" style="width:16px;height:16px;flex-shrink:0;"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" /></svg><span>@mensajeError</span></div>
}
@if (!string.IsNullOrEmpty(mensajeExito))
{
    <div class="alert-error" style="margin-bottom:16px;background:rgba(34,197,94,0.1);border-color:rgba(34,197,94,0.3);"><span style="color:#4ade80;">@mensajeExito</span></div>
}

@if (cargando)
{
    <div class="loading">Cargando empleados...</div>
}
else
{
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Sucursal</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th style="text-align:center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in empleados)
                {
                    <tr>
                        <td class="td-mono">@emp.Id_empleado</td>
                        <td style="font-weight:600;">@emp.NombreCompleto</td>
                        <td class="td-mono">@emp.Cedula</td>
                        <td>@(emp.Telefono ?? "—")</td>
                        <td>@(emp.Email ?? "—")</td>
                        <td>@emp.NombreSucursal</td>
                        <td>
                            <span class="badge @GetRolBadge(emp.Rol)">@emp.Rol</span>
                        </td>
                        <td>
                            @if (emp.Activo)
                            {
                                <span class="badge badge-active"><span class="badge-dot" style="background:#22c55e;"></span>Activo</span>
                            }
                            else
                            {

                                <span class="badge badge-inactive"><span class="badge-dot" style="background:#ef4444;animation:none;"></span>Inactivo</span>
                            }
                        </td>
                        <td>
                            <div class="td-actions" style="display:flex; gap:8px; justify-content:center;">
                                <button class="btn-icon" @onclick="() => AbrirFormularioEditar(emp)" title="Editar">
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                </button>
                                @if (emp.Activo)
                                {
                                    <button class="btn-icon danger" @onclick="() => ConfirmarDesactivar(emp)" title="Desactivar">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-icon success" @onclick="() => ReactivarEmpleado(emp)" title="Reactivar">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!empleados.Any())
                {
                    <tr><td colspan="9"><div class="empty-state">No hay empleados registrados</div></td></tr>
                }
            </tbody>
        </table>
    </div>
}

@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <h2 class="modal-title">@(esNuevo ? "Nuevo Empleado" : "Editar Empleado")</h2>
                    <p class="modal-subtitle">@(esNuevo ? "Registra un nuevo empleado" : "Modifica los datos del empleado")</p>
                </div>
                <button class="btn-close-modal" @onclick="CerrarModal">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="modal-deco-line"></div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(mensajeErrorModal))
                {
                    <div class="alert-error"><svg fill="currentColor" viewBox="0 0 20 20" style="width:16px;height:16px;flex-shrink:0;"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" /></svg><span>@mensajeErrorModal</span></div>
                }
                @if (!string.IsNullOrEmpty(mensajeExitoModal))
                {
                    <div class="alert-error" style="background:rgba(34,197,94,0.1);border-color:rgba(34,197,94,0.3);"><span style="color:#4ade80;">@mensajeExitoModal</span></div>
                }

                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Nombre *</label>
                        <input @bind="form.Nombre" class="input-field" placeholder="Nombre" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Apellido *</label>
                        <input @bind="form.Apellido" class="input-field" placeholder="Apellido" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Cédula *</label>
                        <input @bind="form.Cedula" class="input-field" placeholder="000-0000000-0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Teléfono</label>
                        <input @bind="form.Telefono" class="input-field" placeholder="809-000-0000" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input @bind="form.Email" class="input-field" placeholder="correo@email.com" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fecha de Ingreso *</label>
                        <input type="date" @bind="form.FechaIngreso" class="input-field" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sucursal *</label>
                        <select @bind="form.IdSucursal" class="input-field">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var s in sucursales)
                            {
                                <option value="@s.Id_sucursal">@s.Nombre_sucursal</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Usuario del sistema *</label>
                        <select @bind="form.IdUsuario" class="input-field">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var u in usuarios)
                            {
                                <option value="@u.Id_usuario">@u.Nombre_usuario (@u.Rol)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn-primary" @onclick="Guardar" disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (mostrarConfirm)
{
    <div class="modal-overlay" @onclick="() => mostrarConfirm = false">
        <div class="modal" style="max-width:440px;" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <h2 class="modal-title">Desactivar empleado</h2>
                    <p class="modal-subtitle">Esta acción puede revertirse</p>
                </div>
                <button class="btn-close-modal" @onclick="() => mostrarConfirm = false">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="modal-deco-line" style="background:linear-gradient(to right,#ef4444,transparent);"></div>
            <div class="modal-body">
                <div class="alert-warning">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                    <div>
                        <div class="alert-warning-title">Confirmar desactivación</div>
                        <div class="alert-warning-text">El empleado <strong>@empleadoADesactivar?.NombreCompleto</strong> quedará inactivo.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn-secondary" @onclick="() => mostrarConfirm = false">Cancelar</button>
                    <button class="btn-primary" style="background:linear-gradient(to right,#dc2626,#ef4444);" @onclick="EjecutarDesactivar" disabled="@guardando">
                        @(guardando ? "Procesando..." : "Sí, desactivar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<EmpleadoDto> empleados = new();
    List<SucursalDto> sucursales = new();
    List<UsuarioDto> usuarios = new();
    bool cargando = true; bool mostrarModal = false; bool mostrarConfirm = false;
    bool esNuevo = true; bool guardando = false;
    int empleadoEditId = 0;
    string mensajeError = string.Empty; string mensajeExito = string.Empty;
    string mensajeErrorModal = string.Empty; string mensajeExitoModal = string.Empty;
    EmpleadoForm form = new();
    EmpleadoDto? empleadoADesactivar = null;

    protected override async Task OnInitializedAsync() => await CargarDatos();

    async Task CargarDatos()
    {
        cargando = true;
        try { empleados = await Api.GetEmpleadosAsync(); sucursales = await Api.GetSucursalesAsync(); }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        cargando = false;
    }

    async Task AbrirFormularioNuevo()
    {
        esNuevo = true; form = new EmpleadoForm { FechaIngreso = DateTime.Today };
        mensajeErrorModal = mensajeExitoModal = string.Empty;
        usuarios = await Api.GetUsuariosDisponiblesAsync();
        mostrarModal = true;
    }

    async Task AbrirFormularioEditar(EmpleadoDto emp)
    {
        esNuevo = false; empleadoEditId = emp.Id_empleado;
        form = new EmpleadoForm { Nombre = emp.Nombre, Apellido = emp.Apellido, Cedula = emp.Cedula, Telefono = emp.Telefono, Email = emp.Email, IdSucursal = emp.Id_sucursal, IdUsuario = emp.Id_usuario, FechaIngreso = DateTime.Today };
        mensajeErrorModal = mensajeExitoModal = string.Empty;
        usuarios = await Api.GetUsuariosAsync();
        mostrarModal = true;
    }

    void CerrarModal() => mostrarModal = false;
    void ConfirmarDesactivar(EmpleadoDto emp) { empleadoADesactivar = emp; mostrarConfirm = true; }

    async Task EjecutarDesactivar()
    {
        if (empleadoADesactivar == null) return;
        guardando = true;
        var ok = await Api.DesactivarEmpleadoAsync(empleadoADesactivar.Id_empleado);
        guardando = false; mostrarConfirm = false;
        if (ok) { mensajeExito = $"Empleado '{empleadoADesactivar.NombreCompleto}' desactivado."; mensajeError = string.Empty; await CargarDatos(); await Task.Delay(3000); mensajeExito = string.Empty; StateHasChanged(); }
        else mensajeError = "No se pudo desactivar el empleado.";
    }

    async Task ReactivarEmpleado(EmpleadoDto emp)
    {
        var ok = await Api.DesactivarEmpleadoAsync(emp.Id_empleado, reactivar: true);
        if (ok) { mensajeExito = $"Empleado '{emp.NombreCompleto}' reactivado."; await CargarDatos(); await Task.Delay(3000); mensajeExito = string.Empty; StateHasChanged(); }
    }

    async Task Guardar()
    {
        mensajeErrorModal = mensajeExitoModal = string.Empty;
        if (string.IsNullOrWhiteSpace(form.Nombre) || string.IsNullOrWhiteSpace(form.Apellido) || string.IsNullOrWhiteSpace(form.Cedula) || form.IdSucursal == 0 || form.IdUsuario == 0)
        { mensajeErrorModal = "Completa todos los campos obligatorios."; return; }

        guardando = true;
        bool ok = esNuevo
            ? await Api.CrearEmpleadoAsync(new { IdUsuario = form.IdUsuario, IdSucursal = form.IdSucursal, Cedula = form.Cedula, Nombre = form.Nombre, Apellido = form.Apellido, Telefono = form.Telefono, Email = form.Email, FechaIngreso = form.FechaIngreso })
            : await Api.ActualizarEmpleadoAsync(empleadoEditId, new { Nombre = form.Nombre, Apellido = form.Apellido, Telefono = form.Telefono, Email = form.Email, IdSucursal = form.IdSucursal });
        guardando = false;

        if (ok) { mensajeExitoModal = esNuevo ? "Empleado creado correctamente." : "Empleado actualizado correctamente."; await CargarDatos(); await Task.Delay(1500); CerrarModal(); }
        else mensajeErrorModal = "Ocurrió un error. Verifica los datos e intenta de nuevo.";
    }

    string GetRolBadge(string rol) => rol?.ToLower() switch
    {
        "admin" => "badge-indigo",
        "cajero" => "badge-amber",
        "tecnico" => "badge-purple",
        _ => "badge-blue"
    };

    class EmpleadoForm { public string Nombre { get; set; } = string.Empty; public string Apellido { get; set; } = string.Empty; public string Cedula { get; set; } = string.Empty; public string? Telefono { get; set; } public string? Email { get; set; } public int IdSucursal { get; set; } public int IdUsuario { get; set; } public DateTime FechaIngreso { get; set; } = DateTime.Today; }
}