@page "/productos"
@using TransmisionesCaja.Services
@using TransmisionesCaja.Auth
@inject ApiService ApiService
@inject AuthService Auth
@rendermode InteractiveServer

<div class="page-header">
    <div>
        <h2>📦 Productos</h2>
        <p>Catálogo de productos disponibles</p>
    </div>
    @if (Auth.EsAdmin())
    {
        <button class="btn-primary" @onclick="MostrarModalProducto">+ Nuevo Producto</button>
    }
</div>

<div style="margin-bottom:16px;">
    <input type="text" class="input-buscar" placeholder="Buscar producto..."
       value="@filtro" @oninput="OnFiltroChanged" />
</div>

@if (cargando)
{
    <div class="loading">Cargando productos...</div>
}
else
{
    <div class="tabla-wrapper">
        <table class="tabla">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Descripción</th>
                    <th>Marca</th>
                    <th>Categoría</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Estado</th>
                    @if (Auth.EsAdmin()) { <th>Acciones</th> }
                </tr>
            </thead>
            <tbody>
                @if (productosFiltrados.Any())
                {
                    @foreach (var p in productosFiltrados)
                    {
                        <tr>
                            <td>@p.Id_producto</td>
                            <td><strong>@p.Descripcion_producto</strong></td>
                            <td>@(p.Marca ?? "—")</td>
                            <td>@(p.Categoria ?? "—")</td>
                            <td><strong>RD$ @p.Precio_unitario.ToString("N2")</strong></td>
                            <td>
                                @if (p.Stock_actual <= 5)
                                { <span class="badge-alerta">⚠️ @p.Stock_actual</span> }
                                else
                                { <span>@p.Stock_actual</span> }
                            </td>
                            <td>
                                @if (p.Activo) { <span class="badge-activo">Activo</span> }
                                else { <span class="badge-inactivo">Inactivo</span> }
                            </td>
                            @if (Auth.EsAdmin())
                            {
                                <td style="display:flex; gap:6px;">
                                    <button class="btn-edit" @onclick="() => EditarProducto(p)">✏️ Editar</button>
                                </td>
                            }
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" style="text-align:center; padding:30px; color:#64748b;">No hay productos registrados</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(editando ? "Editar Producto" : "Nuevo Producto")</h3>
                <button class="btn-close" @onclick="CerrarModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(mensajeError))
                { <div class="alert-error">⚠️ @mensajeError</div> }
                @if (!string.IsNullOrEmpty(mensajeExito))
                { <div class="alert-exito">✅ @mensajeExito</div> }

                <div class="form-grid">
                    <div class="form-group" style="grid-column: span 2">
                        <label>Descripción *</label>
                        <input @bind="form.Descripcion" class="input-field" placeholder="Ej: Aceite Motor 5W30" />
                    </div>
                    <div class="form-group">
                        <label>Marca</label>
                        <input @bind="form.Marca" class="input-field" placeholder="Ej: Mobil" />
                    </div>
                    <div class="form-group">
                        <label>Categoría *</label>
                        <select @bind="form.IdCategoria" class="input-field">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var c in categorias)
                            {
                                <option value="@c.Id_categoria">@c.Nombre_categoria</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Tipo Transmisión *</label>
                        <select @bind="form.IdTipoTrans" class="input-field">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var t in tiposTransmision)
                            {
                                <option value="@t.Id_tipo_trans">@t.Descripcion</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Stock Inicial *</label>
                        <input type="number" @bind="form.StockInicial" class="input-field" min="0" />
                    </div>
                    <div class="form-group">
                        <label>Precio Unitario (RD$) *</label>
                        <input type="number" @bind="form.PrecioUnitario" class="input-field" min="0" step="0.01" />
                    </div>
                    <div class="form-group">
                        <label>Costo Unitario (RD$) *</label>
                        <input type="number" @bind="form.CostoUnitario" class="input-field" min="0" step="0.01" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CerrarModal">Cancelar</button>
                <button class="btn-primary" @onclick="GuardarProducto" disabled="@guardando">
                    @(guardando ? "Guardando..." : "💾 Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    List<ProductoDto>     productos         = new();
    List<ProductoDto>     productosFiltrados = new();
    List<CategoriaDto>    categorias        = new();
    List<TipoTransDto>    tiposTransmision  = new();
    bool cargando = true; bool mostrarModal = false; bool editando = false; bool guardando = false;
    string filtro = string.Empty;
    string mensajeError = string.Empty; string mensajeExito = string.Empty;
    ProductoForm form = new();
    int editId = 0;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    async Task CargarDatos()
    {
        try
        {
            productos          = await ApiService.GetProductosAsync();
            categorias         = await ApiService.GetCategoriasAsync();
            tiposTransmision   = await ApiService.GetTiposTransmisionAsync();
            productosFiltrados = productos.ToList();
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        cargando = false;
    }

    void OnFiltroChanged(ChangeEventArgs e)
    {
        filtro = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(filtro))
            productosFiltrados = productos.ToList();
        else
            productosFiltrados = productos
                .Where(p => p.Descripcion_producto.Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                            (p.Marca ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase))
                .ToList();
    }

    void MostrarModalProducto() { editando = false; form = new(); mensajeError = mensajeExito = string.Empty; mostrarModal = true; }
    void EditarProducto(ProductoDto p)
    {
        editando = true; editId = p.Id_producto;
        form = new() { Descripcion = p.Descripcion_producto, Marca = p.Marca, PrecioUnitario = p.Precio_unitario, CostoUnitario = p.Costo_unitario, StockInicial = p.Stock_actual };
        mensajeError = mensajeExito = string.Empty; mostrarModal = true;
    }
    void CerrarModal() => mostrarModal = false;

    async Task GuardarProducto()
    {
        if (string.IsNullOrWhiteSpace(form.Descripcion) || form.IdCategoria == 0 || form.IdTipoTrans == 0 || form.PrecioUnitario <= 0)
        { mensajeError = "Completa todos los campos obligatorios."; return; }

        if (form.PrecioUnitario < form.CostoUnitario)
        { mensajeError = "El precio unitario no puede ser menor al costo."; return; }

        guardando = true;
        bool ok;
        if (editando)
            ok = await ApiService.ActualizarPrecioProductoAsync(editId, form.PrecioUnitario, form.CostoUnitario);
        else
            ok = await ApiService.CrearProductoAsync(new {
                IdCategoria    = form.IdCategoria,
                IdTipoTrans    = form.IdTipoTrans,
                Descripcion    = form.Descripcion,
                Marca          = form.Marca,
                PrecioUnitario = form.PrecioUnitario,
                CostoUnitario  = form.CostoUnitario,
                StockInicial   = form.StockInicial
            });

        guardando = false;
        if (ok) { mensajeExito = "Guardado correctamente."; await CargarDatos(); await Task.Delay(1500); CerrarModal(); }
        else mensajeError = "Error al guardar. Intenta de nuevo.";
    }

    class ProductoForm
    {
        public string  Descripcion    { get; set; } = string.Empty;
        public string? Marca          { get; set; }
        public int     IdCategoria    { get; set; }
        public int     IdTipoTrans    { get; set; }
        public decimal PrecioUnitario { get; set; }
        public decimal CostoUnitario  { get; set; }
        public int     StockInicial   { get; set; }
    }
}

<style>
    .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
    .page-header h2 { margin:0; font-size:22px; color:#1e293b; }
    .page-header p  { margin:4px 0 0; color:#64748b; font-size:13px; }
    .input-buscar { width:320px; padding:9px 12px; border:1.5px solid #d1d5db; border-radius:8px; font-size:14px; }
    .input-buscar:focus { outline:none; border-color:#0ea5e9; }
    .btn-primary { background:#0ea5e9; color:white; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-size:14px; font-weight:600; }
    .btn-primary:hover:not(:disabled) { background:#0284c7; }
    .btn-primary:disabled { background:#93c5fd; cursor:not-allowed; }
    .btn-secondary { background:#e2e8f0; color:#374151; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; }
    .btn-edit { background:#f1f5f9; border:1px solid #d1d5db; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .tabla-wrapper { background:white; border-radius:10px; box-shadow:0 1px 4px rgba(0,0,0,0.08); overflow:hidden; }
    .tabla { width:100%; border-collapse:collapse; font-size:13px; }
    .tabla thead { background:#f8fafc; }
    .tabla th { padding:12px 14px; text-align:left; font-size:12px; color:#64748b; text-transform:uppercase; letter-spacing:.5px; border-bottom:1px solid #e2e8f0; }
    .tabla td { padding:12px 14px; border-bottom:1px solid #f1f5f9; color:#374151; }
    .tabla tr:last-child td { border-bottom:none; }
    .tabla tr:hover td { background:#f8fafc; }
    .badge-activo  { background:#dcfce7; color:#166534; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-inactivo{ background:#fee2e2; color:#991b1b; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-alerta  { background:#fef9c3; color:#854d0e; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .loading { text-align:center; padding:40px; color:#64748b; }
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000; }
    .modal { background:white; border-radius:12px; width:620px; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .modal-header { display:flex; justify-content:space-between; align-items:center; padding:20px 24px; border-bottom:1px solid #e2e8f0; }
    .modal-header h3 { margin:0; font-size:17px; color:#1e293b; }
    .btn-close { background:none; border:none; font-size:18px; cursor:pointer; color:#64748b; }
    .modal-body { padding:24px; }
    .modal-footer { padding:16px 24px; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end; gap:10px; }
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-group label { font-size:13px; font-weight:600; color:#374151; }
    .input-field { padding:9px 12px; border:1.5px solid #d1d5db; border-radius:8px; font-size:14px; }
    .input-field:focus { outline:none; border-color:#0ea5e9; }
    .alert-error { background:#fef2f2; border:1px solid #fecaca; color:#dc2626; padding:10px 14px; border-radius:8px; font-size:13px; margin-bottom:14px; }
    .alert-exito { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; padding:10px 14px; border-radius:8px; font-size:13px; margin-bottom:14px; }
</style>