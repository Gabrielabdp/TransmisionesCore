@page "/empleados"
@using TransmisionesCaja.Auth
@using TransmisionesCaja.Services
@inject ApiService Api
@inject AuthService Auth
@rendermode InteractiveServer

@if (!Auth.EsAdmin())
{
    <div class="acceso-denegado">🚫 Solo los administradores pueden acceder a esta sección.</div>
    return;
}

<div class="page-header">
    <div>
        <h2>👤 Empleados</h2>
        <p>Gestión del personal del sistema</p>
    </div>
    <button class="btn-primary" @onclick="AbrirFormularioNuevo">+ Nuevo Empleado</button>
</div>

@if (!string.IsNullOrEmpty(mensajeError))
{ <div class="alert-error" style="margin-bottom:16px;">⚠️ @mensajeError</div> }
@if (!string.IsNullOrEmpty(mensajeExito))
{ <div class="alert-exito" style="margin-bottom:16px;">✅ @mensajeExito</div> }

@if (cargando)
{
    <div class="loading">Cargando empleados...</div>
}
else
{
    <div class="tabla-wrapper">
        <table class="tabla">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Sucursal</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in empleados)
                {
                    <tr>
                        <td>@emp.Id_empleado</td>
                        <td><strong>@emp.NombreCompleto</strong></td>
                        <td>@emp.Cedula</td>
                        <td>@(emp.Telefono ?? "—")</td>
                        <td>@(emp.Email ?? "—")</td>
                        <td>@emp.NombreSucursal</td>
                        <td><span class="badge-rol-@emp.Rol.ToLower()">@emp.Rol</span></td>
                        <td>
                            @if (emp.Activo)
                            { <span class="badge-activo">Activo</span> }
                            else
                            { <span class="badge-inactivo">Inactivo</span> }
                        </td>
                        <td class="acciones">
                            <button class="btn-edit" @onclick="() => AbrirFormularioEditar(emp)">✏️ Editar</button>
                            @if (emp.Activo)
                            {
                                <button class="btn-danger" @onclick="() => ConfirmarDesactivar(emp)">🚫 Desactivar</button>
                            }
                            else
                            {
                                <button class="btn-success" @onclick="() => ReactivarEmpleado(emp)">✅ Reactivar</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- MODAL FORMULARIO -->
@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(esNuevo ? "Nuevo Empleado" : "Editar Empleado")</h3>
                <button class="btn-close" @onclick="CerrarModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(mensajeErrorModal))
                { <div class="alert-error">⚠️ @mensajeErrorModal</div> }
                @if (!string.IsNullOrEmpty(mensajeExitoModal))
                { <div class="alert-exito">✅ @mensajeExitoModal</div> }

                <div class="form-grid">
                    <div class="form-group">
                        <label>Nombre *</label>
                        <input @bind="form.Nombre" class="input-field" placeholder="Nombre" />
                    </div>
                    <div class="form-group">
                        <label>Apellido *</label>
                        <input @bind="form.Apellido" class="input-field" placeholder="Apellido" />
                    </div>
                    <div class="form-group">
                        <label>Cédula *</label>
                        <input @bind="form.Cedula" class="input-field" placeholder="000-0000000-0" />
                    </div>
                    <div class="form-group">
                        <label>Teléfono</label>
                        <input @bind="form.Telefono" class="input-field" placeholder="809-000-0000" />
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input @bind="form.Email" class="input-field" placeholder="correo@email.com" />
                    </div>
                    <div class="form-group">
                        <label>Fecha de Ingreso *</label>
                        <input type="date" @bind="form.FechaIngreso" class="input-field" />
                    </div>
                    <div class="form-group">
                        <label>Sucursal *</label>
                        <select @bind="form.IdSucursal" class="input-field">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var s in sucursales)
                            {
                                <option value="@s.Id_sucursal">@s.Nombre_sucursal</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Usuario del sistema *</label>
                        <select @bind="form.IdUsuario" class="input-field">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var u in usuarios)
                            {
                                <option value="@u.Id_usuario">@u.Nombre_usuario (@u.Rol)</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CerrarModal">Cancelar</button>
                <button class="btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "💾 Guardar")
                </button>
            </div>
        </div>
    </div>
}

<!-- MODAL CONFIRMAR DESACTIVAR -->
@if (mostrarConfirm)
{
    <div class="modal-overlay" @onclick="() => mostrarConfirm = false">
        <div class="modal-confirm" @onclick:stopPropagation>
            <h3>⚠️ ¿Desactivar empleado?</h3>
            <p>El empleado <strong>@empleadoADesactivar?.NombreCompleto</strong> quedará inactivo.</p>
            <div class="confirm-footer">
                <button class="btn-secondary" @onclick="() => mostrarConfirm = false">Cancelar</button>
                <button class="btn-danger" @onclick="EjecutarDesactivar" disabled="@guardando">
                    @(guardando ? "Procesando..." : "Sí, desactivar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    List<EmpleadoDto> empleados  = new();
    List<SucursalDto> sucursales = new();
    List<UsuarioDto>  usuarios   = new();

    bool   cargando          = true;
    bool   mostrarModal      = false;
    bool   mostrarConfirm    = false;
    bool   esNuevo           = true;
    bool   guardando         = false;
    int    empleadoEditId    = 0;

    // mensajes globales (tabla)
    string mensajeError      = string.Empty;
    string mensajeExito      = string.Empty;
    // mensajes dentro del modal
    string mensajeErrorModal = string.Empty;
    string mensajeExitoModal = string.Empty;

    EmpleadoForm  form                 = new();
    EmpleadoDto?  empleadoADesactivar  = null;

    protected override async Task OnInitializedAsync() => await CargarDatos();

    async Task CargarDatos()
    {
        cargando = true;
        try
        {
            empleados  = await Api.GetEmpleadosAsync();
            sucursales = await Api.GetSucursalesAsync();
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        cargando = false;
    }

    async Task AbrirFormularioNuevo()
    {
        esNuevo              = true;
        form                 = new EmpleadoForm { FechaIngreso = DateTime.Today };
        mensajeErrorModal    = mensajeExitoModal = string.Empty;
        // solo usuarios SIN empleado asignado
        usuarios             = await Api.GetUsuariosDisponiblesAsync();
        mostrarModal         = true;
    }

    async Task AbrirFormularioEditar(EmpleadoDto emp)
    {
        esNuevo           = false;
        empleadoEditId    = emp.Id_empleado;
        form = new EmpleadoForm
        {
            Nombre       = emp.Nombre,
            Apellido     = emp.Apellido,
            Cedula       = emp.Cedula,
            Telefono     = emp.Telefono,
            Email        = emp.Email,
            IdSucursal   = emp.Id_sucursal,
            IdUsuario    = emp.Id_usuario,
            FechaIngreso = DateTime.Today
        };
        mensajeErrorModal = mensajeExitoModal = string.Empty;
        // todos los usuarios para que aparezca el asignado actual
        usuarios          = await Api.GetUsuariosAsync();
        mostrarModal      = true;
    }

    void CerrarModal() => mostrarModal = false;

    void ConfirmarDesactivar(EmpleadoDto emp)
    {
        empleadoADesactivar = emp;
        mostrarConfirm      = true;
    }

    async Task EjecutarDesactivar()
    {
        if (empleadoADesactivar == null) return;
        guardando = true;
        var ok = await Api.DesactivarEmpleadoAsync(empleadoADesactivar.Id_empleado);
        guardando      = false;
        mostrarConfirm = false;

        if (ok)
        {
            mensajeExito = $"Empleado '{empleadoADesactivar.NombreCompleto}' desactivado.";
            mensajeError = string.Empty;
            await CargarDatos();
            await Task.Delay(3000);
            mensajeExito = string.Empty;
            StateHasChanged();
        }
        else
        {
            mensajeError = "No se pudo desactivar el empleado.";
        }
    }

    async Task ReactivarEmpleado(EmpleadoDto emp)
    {
        var ok = await Api.DesactivarEmpleadoAsync(emp.Id_empleado, reactivar: true);
        if (ok)
        {
            mensajeExito = $"Empleado '{emp.NombreCompleto}' reactivado.";
            await CargarDatos();
            await Task.Delay(3000);
            mensajeExito = string.Empty;
            StateHasChanged();
        }
    }

    async Task Guardar()
    {
        mensajeErrorModal = mensajeExitoModal = string.Empty;

        if (string.IsNullOrWhiteSpace(form.Nombre)   ||
            string.IsNullOrWhiteSpace(form.Apellido) ||
            string.IsNullOrWhiteSpace(form.Cedula)   ||
            form.IdSucursal == 0 || form.IdUsuario == 0)
        {
            mensajeErrorModal = "Completa todos los campos obligatorios.";
            return;
        }

        guardando = true;
        bool ok;

        if (esNuevo)
        {
            ok = await Api.CrearEmpleadoAsync(new
            {
                IdUsuario    = form.IdUsuario,
                IdSucursal   = form.IdSucursal,
                Cedula       = form.Cedula,
                Nombre       = form.Nombre,
                Apellido     = form.Apellido,
                Telefono     = form.Telefono,
                Email        = form.Email,
                FechaIngreso = form.FechaIngreso
            });
        }
        else
        {
            ok = await Api.ActualizarEmpleadoAsync(empleadoEditId, new
            {
                Nombre     = form.Nombre,
                Apellido   = form.Apellido,
                Telefono   = form.Telefono,
                Email      = form.Email,
                IdSucursal = form.IdSucursal
            });
        }

        guardando = false;

        if (ok)
        {
            mensajeExitoModal = esNuevo ? "Empleado creado correctamente." : "Empleado actualizado correctamente.";
            await CargarDatos();
            await Task.Delay(1500);
            CerrarModal();
        }
        else
        {
            mensajeErrorModal = "Ocurrió un error. Verifica los datos e intenta de nuevo.";
        }
    }

    class EmpleadoForm
    {
        public string   Nombre       { get; set; } = string.Empty;
        public string   Apellido     { get; set; } = string.Empty;
        public string   Cedula       { get; set; } = string.Empty;
        public string?  Telefono     { get; set; }
        public string?  Email        { get; set; }
        public int      IdSucursal   { get; set; }
        public int      IdUsuario    { get; set; }
        public DateTime FechaIngreso { get; set; } = DateTime.Today;
    }
}

<style>
    .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; }
    .page-header h2 { margin:0; font-size:22px; color:#1e293b; }
    .page-header p { margin:4px 0 0; color:#64748b; font-size:13px; }
    .btn-primary { background:#0ea5e9; color:white; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-size:14px; font-weight:600; }
    .btn-primary:hover:not(:disabled) { background:#0284c7; }
    .btn-primary:disabled { background:#93c5fd; cursor:not-allowed; }
    .btn-secondary { background:#e2e8f0; color:#374151; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-size:14px; }
    .btn-edit { background:#f1f5f9; border:1px solid #d1d5db; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .btn-edit:hover { background:#e2e8f0; }
    .btn-danger { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .btn-danger:hover:not(:disabled) { background:#fecaca; }
    .btn-danger:disabled { opacity:.6; cursor:not-allowed; }
    .btn-success { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .btn-success:hover { background:#bbf7d0; }
    .acciones { display:flex; gap:6px; align-items:center; }
    .tabla-wrapper { background:white; border-radius:10px; box-shadow:0 1px 4px rgba(0,0,0,0.08); overflow:hidden; }
    .tabla { width:100%; border-collapse:collapse; font-size:13px; }
    .tabla thead { background:#f8fafc; }
    .tabla th { padding:12px 14px; text-align:left; font-size:12px; color:#64748b; text-transform:uppercase; letter-spacing:.5px; border-bottom:1px solid #e2e8f0; }
    .tabla td { padding:12px 14px; border-bottom:1px solid #f1f5f9; color:#374151; vertical-align:middle; }
    .tabla tr:last-child td { border-bottom:none; }
    .tabla tr:hover td { background:#f8fafc; }
    .badge-activo { background:#dcfce7; color:#166534; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-inactivo { background:#fee2e2; color:#991b1b; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; }
    .badge-rol-admin { background:#dbeafe; color:#1e40af; padding:2px 8px; border-radius:10px; font-size:11px; }
    .badge-rol-cajero { background:#fef9c3; color:#854d0e; padding:2px 8px; border-radius:10px; font-size:11px; }
    .badge-rol-tecnico { background:#f3e8ff; color:#6b21a8; padding:2px 8px; border-radius:10px; font-size:11px; }
    .loading { text-align:center; padding:40px; color:#64748b; }
    .acceso-denegado { background:#fef2f2; border:1px solid #fecaca; color:#dc2626; padding:20px; border-radius:8px; text-align:center; }
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000; }
    .modal { background:white; border-radius:12px; width:640px; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .modal-confirm { background:white; border-radius:12px; width:420px; padding:28px; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .modal-confirm h3 { margin:0 0 12px; font-size:17px; color:#1e293b; }
    .modal-confirm p { margin:0 0 20px; color:#64748b; font-size:14px; }
    .confirm-footer { display:flex; justify-content:flex-end; gap:10px; }
    .modal-header { display:flex; justify-content:space-between; align-items:center; padding:20px 24px; border-bottom:1px solid #e2e8f0; }
    .modal-header h3 { margin:0; font-size:17px; color:#1e293b; }
    .btn-close { background:none; border:none; font-size:18px; cursor:pointer; color:#64748b; }
    .modal-body { padding:24px; }
    .modal-footer { padding:16px 24px; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end; gap:10px; }
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-group label { font-size:13px; font-weight:600; color:#374151; }
    .input-field { padding:9px 12px; border:1.5px solid #d1d5db; border-radius:8px; font-size:14px; }
    .input-field:focus { outline:none; border-color:#0ea5e9; }
    .alert-error { background:#fef2f2; border:1px solid #fecaca; color:#dc2626; padding:10px 14px; border-radius:8px; font-size:13px; margin-bottom:14px; }
    .alert-exito { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; padding:10px 14px; border-radius:8px; font-size:13px; margin-bottom:14px; }
</style>