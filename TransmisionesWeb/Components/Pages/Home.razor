                    <h5 class="fw-bold">📞 Teléfono</h5>
                    <p class="text-white-50">+1 (809) 123-4567</p>
                </div>
                <div>
                    <h5 class="fw-bold">⏰ Horario</h5>
                    <p class="text-white-50">Lun - Vie: 8:00 AM - 6:00 PM<br>Sáb: 9:00 AM - 1:00 PM</p>
                </div>
            </div>
