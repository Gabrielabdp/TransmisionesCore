@page "/"

<PageTitle>Dashboard - Transmisiones Core</PageTitle>

<div class="container py-4">
    <!-- Hero Section -->
    <div class="hero-banner p-5 mb-5 rounded-4 shadow-lg text-white d-flex flex-column align-items-center justify-content-center text-center">
